<% layout("/layouts/boilerplate") %>
<div class="listing-form-page">
  <div class="listing-form-shell">
    <aside class="listing-preview-panel">
      <div class="preview-image-wrap">
        <img
          src="<%= listing.image %>"
          alt="<%= listing.title %>"
          class="preview-image"
          id="listingImagePreview"
        >
      </div>
      <div class="preview-card">
        <p class="preview-eyebrow">Editing listing</p>
        <h2><%= listing.title %></h2>
        <p><%= listing.location %>, <%= listing.country %></p>
        <div class="preview-price">
          ₹ <%= listing.price.toLocaleString("en-IN") %>
          <span>/ night</span>
        </div>
      </div>
    </aside>
    <section class="listing-form-panel">
      <div class="listing-form-heading">
        <p class="form-eyebrow">Host dashboard</p>
        <h1>Update your listing</h1>
        <p>Keep your stay details accurate so guests know exactly what to expect.</p>
      </div>
      <form
        method="POST"
        action="/listings/<%= listing._id %>?_method=PUT"
        enctype="multipart/form-data"
        novalidate
        class="needs-validation listing-edit-form"
      >
        <div class="form-section">
          <h2>Basic details</h2>
          <div class="mb-3">
            <label class="form-label" for="title">Title</label>
            <input
              id="title"
              name="listing[title]"
              type="text"
              class="form-control"
              value="<%= listing.title %>"
              placeholder="Beautiful apartment near the beach"
              required
            >
            <div class="invalid-feedback">Title should be valid.</div>
          </div>
          <div class="mb-3">
            <label class="form-label" for="description">Description</label>
            <textarea
              id="description"
              name="listing[description]"
              class="form-control"
              rows="4"
              placeholder="Tell guests what makes your place special"
              required
            ><%= listing.description %></textarea>
            <div class="invalid-feedback">Please enter a short description.</div>
          </div>
          <div class="mb-3">
            <label class="form-label" for="category">Category</label>
            <select
              id="category"
              name="listing[category]"
              class="form-select"
              required
            >
              <option value="Trending" <%= listing.category === "Trending" ? "selected" : "" %>>Trending</option>
              <option value="Rooms" <%= listing.category === "Rooms" ? "selected" : "" %>>Rooms</option>
              <option value="Spiritual" <%= listing.category === "Spiritual" ? "selected" : "" %>>Spiritual</option>
              <option value="Heritage" <%= listing.category === "Heritage" ? "selected" : "" %>>Heritage</option>
              <option value="Nature" <%= listing.category === "Nature" ? "selected" : "" %>>Nature</option>
              <option value="Mountains" <%= listing.category === "Mountains" ? "selected" : "" %>>Mountains</option>
              <option value="Beach" <%= listing.category === "Beach" ? "selected" : "" %>>Beach</option>
              <option value="Pools" <%= listing.category === "Pools" ? "selected" : "" %>>Pools</option>
              <option value="Camping" <%= listing.category === "Camping" ? "selected" : "" %>>Camping</option>
              <option value="Farm" <%= listing.category === "Farm" ? "selected" : "" %>>Farm</option>
              <option value="City" <%= listing.category === "City" ? "selected" : "" %>>City</option>
            </select>
            <div class="invalid-feedback">Please choose a category.</div>
          </div>
        </div>
        <div class="form-section">
          <h2>Photo</h2>
          <div class="mb-3">
            <label class="form-label" for="image">Replace image</label>
            <input
              id="image"
              name="listing[image]"
              type="file"
              class="form-control"
              accept="image/*"
            >
            <p class="form-text mb-0">Leave this empty to keep the current photo.</p>
          </div>
        </div>
        <div class="form-section">
          <h2>Price and location</h2>
          <div class="row">
            <div class="mb-3 col-md-4">
              <label class="form-label" for="price">Price</label>
              <div class="price-input-wrap">
                <span>₹</span>
                <input
                  id="price"
                  name="listing[price]"
                  type="number"
                  class="form-control"
                  value="<%= listing.price %>"
                  min="0"
                  required
                >
              </div>
              <div class="invalid-feedback">Price should be valid.</div>
            </div>
            <div class="mb-3 col-md-4">
              <label class="form-label" for="maxGuests">Max guests</label>
              <input
                id="maxGuests"
                name="listing[maxGuests]"
                type="number"
                class="form-control"
                value="<%= listing.maxGuests || 4 %>"
                min="1"
                max="16"
                required
              >
              <div class="invalid-feedback">Guests should be between 1 and 16.</div>
            </div>
            <div class="mb-3 col-md-4">
              <label class="form-label" for="country">Country</label>
              <input
                id="country"
                name="listing[country]"
                type="text"
                class="form-control"
                value="<%= listing.country %>"
                placeholder="India"
                required
              >
              <div class="invalid-feedback">Country name should be valid.</div>
            </div>
          </div>
          <div class="mb-0">
            <label class="form-label" for="location">Location</label>
            <input
              id="location"
              name="listing[location]"
              type="text"
              class="form-control"
              value="<%= listing.location %>"
              placeholder="Goa"
              required
            >
            <div class="invalid-feedback">Location should be valid.</div>
          </div>
        </div>
        <div class="form-actions">
          <a href="/listings/<%= listing._id %>" class="btn cancel-btn">
            Cancel
          </a>
          <button class="btn save-listing-btn">
            Update Listing
          </button>
        </div>
      </form>
    </section>
  </div>
</div>
<script>
  const imageInput = document.querySelector("#image");
  const imagePreview = document.querySelector("#listingImagePreview");
  if (imageInput && imagePreview) {
    imageInput.addEventListener("change", () => {
      const file = imageInput.files && imageInput.files[0];
      if (file) {
        imagePreview.src = URL.createObjectURL(file);
      }
    });
  }
</script>
